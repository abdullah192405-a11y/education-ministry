# SPA fallback for Apache. Used after "npm run build": Vite writes index.html to dist/
# and copies this file to dist/.htaccess. Deploy dist/ contents to the web root.
# Requires: mod_rewrite enabled and AllowOverride FileInfo (or All) for this directory.
DirectoryIndex index.html
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
