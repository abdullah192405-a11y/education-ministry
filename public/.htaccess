# SPA fallback: send unknown paths to index.html so client routes (e.g. /sso-callback) work.
# Requires: mod_rewrite enabled and AllowOverride FileInfo (or All) for this directory.
DirectoryIndex index.html
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
