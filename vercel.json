{
    "build": {
        "env": {
            "PUPPETEER_SKIP_CHROMIUM_DOWNLOAD": "true"
        }
    },
    "rewrites": [
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "functions": {
        "api/challenge-report-pdf.js": {
            "maxDuration": 60,
            "memory": 3008,
            "includeFiles": "node_modules/@sparticuz/chromium/**"
        }
    }
}
